+<!DOCTYPE html>
+<html>
+<head>
+  <meta charset="UTF-8">
+  <title>MathJax v3.2.2 harness</title>
+
+  <script>
+    window.MathJax = {
+      tex: {
+        inlineMath: [['$', '$'], ['\\(', '\\)']],
+        displayMath: [['$$', '$$'], ['\\[', '\\]']],
+        packages: { '[+]': ['ams', 'mhchem', 'physics'] }
+      },
+      loader: {
+        load: ['[tex]/ams', '[tex]/mhchem', '[tex]/physics']
+      }
+    };
+  </script>
+
+  <script src="./es5/tex-mml-chtml.js" id="MathJax-script"></script>
+</head>
+
+<body>
+
+<div data-xlet-case="inline">
+  Inline TeX: $E = mc^2$.
+</div>
+
+<div data-xlet-case="block">
+  Display TeX:
+  $$\int_{-\infty}^{\infty} e^{-x^2}\,dx = \sqrt{\pi}.$$
+</div>
+
+<div data-xlet-case="chem">
+  Chemistry:
+  $\ce{2H2 + O2 -> 2H2O}$.
+</div>
+
+<div data-xlet-case="phys">
+  Physics:
+  $\dv{p}{t} = q\bigl(\vb{E} + \vb{v} \times \vb{B}\bigr)$.
+</div>
+
+<div data-xlet-case="mathml">
+  MathML input:
+
+<math xmlns="http://www.w3.org/1998/Math/MathML">
+  <mrow>
+    <msup>
+      <mi>e</mi>
+      <mi>x</mi>
+    </msup>
+    <mo>=</mo>
+    <munder>
+      <mo data-mjx-texclass="OP">∑</mo>
+      <mrow><mi>n</mi><mo>=</mo><mn>0</mn></mrow>
+    </munder>
+    <mfrac>
+      <msup><mi>x</mi><mi>n</mi></msup>
+      <mrow><mi>n</mi><mo>!</mo></mrow>
+    </mfrac>
+  </mrow>
+</math>
+</div>
+
+</body>
+</html>
