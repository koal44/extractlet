{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM", "ES2020"],
    "allowJs": true,
    "checkJs": true,
    "noImplicitAny": false,
  },
  "include": ["src/**/*.js", "test/**/*.js"],
  "exclude": ["node_modules", "dist", "**/gen/**"]
}