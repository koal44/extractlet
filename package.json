{
  "name": "extractlet",
  "version": "0.1.1",
  "description": "Browser extension for sharing GitHub, Stack Exchange, and MediaWiki pages with AI via bespoke HTML-to-Markdown extraction.",
  "private": true,
  "scripts": {
    "build": "tsx --env-file=.env.production scripts/build.ts",
    "build:dev": "tsx --env-file=.env scripts/build.ts",
    "release": "tsx scripts/release.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fix": "vitest run test/fix",
    "test:unit": "vitest run test/unit",
    "test:blocks": "vitest run test/blocks",
    "coverage": "vitest run --coverage",
    "watch:b": "npm-watch build",
    "printfix-mjx": "vite-node scripts/printfix-mjx.ts",
    "vendor": "tsx --env-file=.env scripts/vendor.ts"
  },
  "watch": {
    "build": {
      "patterns": [
        "src/*.ts",
        "build.ts",
        "public/*.{html,css,js}"
      ],
      "quiet": true,
      "extensions": "ts"
    }
  },
  "keywords": [
    "browser-extension",
    "github",
    "stackexchange",
    "stackoverflow",
    "mediawiki",
    "wikipedia",
    "markdown",
    "wikitext",
    "latex",
    "content-extraction"
  ],
  "author": "koal44",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-typescript": "^12.1.4",
    "@stylistic/eslint-plugin": "^5.2.0",
    "@types/js-string-escape": "^1.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.13",
    "@types/webextension-polyfill": "^0.12.3",
    "eslint": "^9.31.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^16.2.0",
    "ignore": "^7.0.5",
    "js-string-escape": "^1.0.1",
    "jsdom": "^26.1.0",
    "npm-watch": "^0.13.0",
    "prettier": "^3.6.2",
    "rollup": "^4.44.1",
    "tslib": "^2.8.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite-node": "^3.2.4",
    "vitest": "^4.0.3",
    "web-ext": "^9.3.0",
    "webextension-polyfill": "^0.12.0"
  },
  "dependencies": {
    "dompurify": "^3.3.1"
  }
}
