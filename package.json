{
  "name": "extractlet",
  "version": "1.0.0",
  "description": "A simple bookmarklet for sharing Wiki and StackExchange posts with your AI assistant using Markdown or Wikitext.",
  "gistUrl": "https://gist.github.com/koal44/77102fb777f9e3eb820db2a342ef965d",
  "main": "build.js",
  "scripts": {
    "build": "tsx --env-file=.env build.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fix": "vitest run --dir ./test/fix",
    "coverage": "vitest run --coverage",
    "watch:b": "npm-watch build",
    "printfix": "vite-node scripts/print-fix.ts"
  },
  "watch": {
    "build": {
      "patterns": [
        "src/*.ts",
        "build.ts",
        "public/*.{html,css,js}"
      ],
      "quiet": true,
      "extensions": "ts"
    }
  },
  "keywords": [
    "bookmarklet",
    "gpt-friendly",
    "share-with-ai",
    "stackexchange",
    "stackoverflow",
    "mediawiki",
    "wikipedia",
    "markdown",
    "wikitext",
    "latex",
    "mathjax",
    "web-scraping"
  ],
  "author": "koal44",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@rollup/plugin-typescript": "^12.1.4",
    "@stylistic/eslint-plugin": "^5.2.0",
    "@types/js-string-escape": "^1.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.13",
    "@types/webextension-polyfill": "^0.12.3",
    "eslint": "^9.31.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "globals": "^16.2.0",
    "ignore": "^7.0.5",
    "js-string-escape": "^1.0.1",
    "jsdom": "^26.1.0",
    "npm-watch": "^0.13.0",
    "prettier": "^3.6.2",
    "rollup": "^4.44.1",
    "tslib": "^2.8.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.36.0",
    "vite-node": "^3.2.4",
    "vitest": "^4.0.3",
    "webextension-polyfill": "^0.12.0"
  }
}
