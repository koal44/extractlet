{
  "manifest_version": 3,
  "name": "extractlet",
  "version": "0.1.1",
  "description": "Share GitHub, Stack Exchange, and wiki pages with your AI.",
  "background": {
    "service_worker": "background.js",
    "scripts": ["browser-polyfill.js", "background.js"],
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-head-16.png",
      "32": "icons/icon-head-32.png",
      "48": "icons/icon-head-48.png",
      "64": "icons/icon-head-64.png",
      "96": "icons/icon-head-96.png",
      "128": "icons/icon-head-128.png",
      "256": "icons/icon-head-256.png",
      "512": "icons/icon-head-512.png"
    },
    "default_title": "Extract with extractlet"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],
  "icons": {
    "16": "icons/icon-head-16.png",
    "32": "icons/icon-head-32.png",
    "48": "icons/icon-head-48.png",
    "64": "icons/icon-head-64.png",
    "96": "icons/icon-full-96.png",
    "128": "icons/icon-full-128.png",
    "256": "icons/icon-full-256.png",
    "512": "icons/icon-full-512.png"
  },
  "incognito": "split",
  "options_ui": {
    "page": "settings-page.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["run-normalize.js"],
      "matches": [
        "*://stackexchange.com/*",
        "*://stackoverflow.com/*",
        "*://serverfault.com/*",
        "*://superuser.com/*",
        "*://askubuntu.com/*",
        "*://stackapps.com/*",
        "*://mathoverflow.net/*",
        "*://*.stackexchange.com/*",
        "*://*.stackoverflow.com/*",
        "*://*.serverfault.com/*",
        "*://*.superuser.com/*",
        "*://*.askubuntu.com/*",
        "*://*.stackapps.com/*",
        "*://*.mathoverflow.net/*",

        "*://*.wikipedia.org/*",
        "*://*.wikibooks.org/*",
        "*://*.wikiversity.org/*",
        "*://*.wikidata.org/*",
        "*://*.wikinews.org/*",
        "*://*.wikiquote.org/*",
        "*://*.wikivoyage.org/*",
        "*://*.wiktionary.org/*",
        "*://*.wikisource.org/*",
        "*://*.wikimedia.org/*",
        "*://*.mediawiki.org/*",

        "*://*.github.com/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "extractlet@koal44",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
